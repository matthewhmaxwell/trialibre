# Trialibre Configuration
# Copy this file to .env and fill in your values.
# For production deployment guidance, see docs/DEPLOYMENT.md

# ─────────────────────────────────────────────────────────────────
# Public domain (only used by docker-compose.prod.yml + Caddy)
# ─────────────────────────────────────────────────────────────────
DOMAIN=trialibre.example.com
ADMIN_EMAIL=ops@example.com

# ─────────────────────────────────────────────────────────────────
# LLM Provider
# ─────────────────────────────────────────────────────────────────
# Provider: anthropic, openai, ollama, openai_compat
CTM_LLM__PROVIDER=ollama

# API Key (required for anthropic/openai, not needed for ollama)
CTM_LLM__API_KEY=

# Model name
CTM_LLM__MODEL=llama3.1

# Base URL (for ollama or openai-compatible endpoints)
CTM_LLM__BASE_URL=http://localhost:11434

# ─────────────────────────────────────────────────────────────────
# API Authentication
# ─────────────────────────────────────────────────────────────────
# JSON array of API keys. When set, all /api/v1/* endpoints (except /health)
# require an X-API-Key header or ?api_key= query parameter.
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
# Leave as [] for no auth (development only — never in production).
CTM_API__API_KEYS=[]

# Comma-separated list of allowed CORS origins. Use ["*"] for development.
# In production, restrict to your frontend's exact URL.
CTM_API__CORS_ORIGINS=["*"]

# ─────────────────────────────────────────────────────────────────
# Sandbox / Demo mode
# ─────────────────────────────────────────────────────────────────
# When true, uses pre-computed sample data instead of calling the LLM.
# Auto-enabled if no LLM is configured.
CTM_SANDBOX__ENABLED=true

# ─────────────────────────────────────────────────────────────────
# Database
# ─────────────────────────────────────────────────────────────────
# Path to the SQLite file (created on first run).
# For PostgreSQL, set CTM_DATABASE__BACKEND=postgresql and
# CTM_DATABASE__POSTGRESQL_URL=postgresql+asyncpg://user:pass@host/db
CTM_DATABASE__SQLITE_PATH=./trialibre.db
